{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "source $HOME/.nvm/nvm.sh && nvm use 24 && cd web && npm run dev"],
      "port": 3000
    },
    {
      "name": "docs",
      "cwd": "docs",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 4321
    },
    {
      "name": "mobile",
      "cwd": "mobile",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start"],
      "port": 8081
    }
  ]
}
