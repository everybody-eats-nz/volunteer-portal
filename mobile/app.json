{
  "expo": {
    "name": "Everybody Eats",
    "slug": "everybody-eats",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "everybody-eats",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.malinmw.everybody-eats",
      "buildNumber": "2",
      "usesAppleSignIn": true,
      "associatedDomains": [
        "webcredentials:volunteers.everybodyeats.nz"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "com.googleusercontent.apps",
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.165743067386-g5qe3p9bge7qtcfb1g8aqbom78lnoeqd"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "nz.co.everybodyeats.volunteers",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0e3a23",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0e3a23",
          "dark": {
            "backgroundColor": "#0e3a23"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Everybody Eats to access your photos to share shift moments.",
          "cameraPermission": "Allow Everybody Eats to use the camera to take shift photos."
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-sharing",
      [
        "expo-notifications",
        {
          "color": "#0e3a23",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Everybody Eats to save shift photos to your library.",
          "savePhotosPermission": "Allow Everybody Eats to save shift photos to your library.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow Everybody Eats to add your upcoming shifts to your calendar so you never miss a mahi."
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f4f88f76-078f-4f65-9841-227b48f19faf"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f4f88f76-078f-4f65-9841-227b48f19faf"
    }
  }
}
