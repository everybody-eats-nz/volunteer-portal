# ============================================================================
# Coolify RUNTIME environment for the volunteer portal (web/)
# ----------------------------------------------------------------------------
# Paste into Coolify → your app → Environment Variables (bulk edit), then fill
# in the real values. These are RUNTIME-only vars.
#
# IMPORTANT: NEXT_PUBLIC_* and the PostHog sourcemap vars are inlined at BUILD
# time, so they live in GitHub Actions (repo Variables/Secrets), NOT here.
# See web/docs/deployment-self-hosting.md for the build-time list.
# ============================================================================

# --- Core ---
TZ=Pacific/Auckland
NODE_ENV=production
# Stays as the live domain once DNS flips. During staging, set to the staging URL.
NEXTAUTH_URL=https://volunteers.everybodyeats.nz

# --- Auth secret (CRITICAL: set BOTH names to the SAME value) ----------------
# The web flow (NextAuth) reads AUTH_SECRET; proxy.ts / impersonate / SSE read
# NEXTAUTH_SECRET explicitly; mobile JWTs are signed with AUTH_SECRET. Use the
# SAME value for both. Reuse the CURRENT production AUTH_SECRET if you can —
# rotating it logs out every web user AND invalidates every mobile app login.
AUTH_SECRET=
NEXTAUTH_SECRET=

# --- Database: Supabase (Sydney). Source from Supabase → Project → Connect ----
# DATABASE_URL: Supavisor transaction pooler (port 6543) for the app.
# DIRECT_URL:   direct connection (port 5432) for migrations only.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres

# --- Supabase storage (service role is sensitive) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Cron (NEW: generate a random value; reuse in the Coolify scheduled tasks)
# Generate: openssl rand -hex 32
CRON_SECRET=

# --- Cloudflare Turnstile secret (NEW; site key is build-time) ---
TURNSTILE_SECRET_KEY=

# --- OAuth provider secrets (source from each provider console) ---
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_SECRET=
# APPLE_CLIENT_SECRET=

# --- OAuth / mobile non-secret IDs (safe to copy from current config) ---
GOOGLE_CLIENT_ID=
FACEBOOK_CLIENT_ID=
GOOGLE_MOBILE_CLIENT_ID_IOS=
# GOOGLE_MOBILE_CLIENT_ID_ANDROID=
# GOOGLE_MOBILE_CLIENT_ID_WEB=
APPLE_MOBILE_BUNDLE_ID=

# --- Email: Campaign Monitor (API key sensitive; template IDs are not) ---
CAMPAIGN_MONITOR_API_KEY=
CAMPAIGN_MONITOR_MIGRATION_EMAIL_ID=
CAMPAIGN_MONITOR_EMAIL_VERIFICATION_ID=
CAMPAIGN_MONITOR_SHIFT_CONFIRMATION_EMAIL_ID=
