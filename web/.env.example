DATABASE_URL="postgresql://postgres:password@localhost:5432/volunteer-portal"
DIRECT_URL="postgresql://postgres:password@localhost:5432/volunteer-portal"
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Timezone (ensures all operations default to New Zealand timezone)
TZ="Pacific/Auckland"

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=phc_KUagYYvjM8OeSSrJ35SUzYodq7JIzXKZhqsotRcI3V2
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# OAuth providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# Mobile OAuth — accepted audiences for id_tokens minted by the native
# Google clients. Must match the client IDs used on the Expo side
# (EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS/ANDROID/WEB), otherwise /api/auth/mobile/oauth
# rejects the token with "Could not verify provider token".
GOOGLE_MOBILE_CLIENT_ID_IOS=""
GOOGLE_MOBILE_CLIENT_ID_ANDROID=""
GOOGLE_MOBILE_CLIENT_ID_WEB=""
# Apple bundle ID — the aud claim Apple mints for Sign in with Apple on native.
# Falls back to APPLE_CLIENT_ID if unset.
APPLE_MOBILE_BUNDLE_ID=""

# Admin notifications (content reports and user blocks from mobile app)
ADMIN_NOTIFICATION_EMAIL=""

# Campaign Monitor Configuration
CAMPAIGN_MONITOR_API_KEY=""
CAMPAIGN_MONITOR_MIGRATION_EMAIL_ID=""
CAMPAIGN_MONITOR_SHIFT_ADMIN_CANCELLATION_EMAIL_ID=""
CAMPAIGN_MONITOR_SHIFT_SHORTAGE_EMAIL_ID=""
CAMPAIGN_MONITOR_SHIFT_CONFIRMATION_EMAIL_ID=""
CAMPAIGN_MONITOR_FIRST_SHIFT_CONFIRMATION_EMAIL_ID=""
CAMPAIGN_MONITOR_VOLUNTEER_CANCELLATION_EMAIL_ID=""
CAMPAIGN_MONITOR_EMAIL_VERIFICATION_ID=""
CAMPAIGN_MONITOR_PARENTAL_CONSENT_APPROVAL_EMAIL_ID=""
CAMPAIGN_MONITOR_USER_INVITATION_EMAIL_ID=""
CAMPAIGN_MONITOR_ANNOUNCEMENT_EMAIL_ID=""

# NOTE: Newsletter list IDs are now managed dynamically via admin page

