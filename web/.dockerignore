# Only the build output and public assets are copied into the image
# (see Dockerfile). Exclude everything heavy or sensitive from the context.
node_modules
.next/cache
# Never bake env files into the image — runtime env is injected by Coolify.
# `next build` copies .env into .next/standalone/, so exclude it recursively
# (a root-anchored `.env*` would miss the nested copy).
**/.env
**/.env.*
!**/.env.example
tests
playwright-report
test-results
docs
*.md
.turbo
.git
